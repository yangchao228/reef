# Required for local development
DATABASE_URL=postgres://reef:reef@localhost:5432/reef
REEF_WORKSPACE_SLUG=
REEF_ADMIN_GITHUB_LOGIN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Recommended for GitHub OAuth login and GitHub App install callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_STATE_SECRET=
GITHUB_APP_NAME=
GITHUB_APP_STATE_SECRET=

# Required for production GitHub App token exchange
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Alternative to GITHUB_APP_PRIVATE_KEY for environments that prefer Base64 secrets
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# Development-only fallbacks
GITHUB_TOKEN=
GITHUB_APP_INSTALLATION_TOKENS_JSON=

# Test-only
SMOKE_BASE_URL=http://127.0.0.1:3000
